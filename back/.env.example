NODE_ENV=development
PORT=4000
AWS_REGION=us-east-1
JWT_SECRET=CHANGE_ME_WITH_A_LONG_RANDOM_SECRET
JWT_EXPIRES_IN=1h
CORS_ORIGIN=http://localhost:5173
INITIAL_BALANCE=500000

